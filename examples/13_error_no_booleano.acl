// Ejemplo 13: Provoca ERR_SEM_05 (Expresión No Booleana).
// Regla 5 — Validación lógica de Expresiones:
//   La condición de un Si/Mientras debe resolverse a Verdadero/Falso.

Definir Modulo Ventas;

// Horario es Variable_Entorno tipo Tiempo (no Booleano).
// ↓↓↓ Falta un operador relacional (<, >, ==).
Si Horario Entonces {
    Permitir Consultar Ventas;
}
